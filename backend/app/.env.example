# Django secret key — generate a unique one for production
DJANGO_SECRET_KEY="change-me-to-a-random-secret"

# Set to False in production
DEBUG=True

# Root directory where RDSO crawler stores files
RDSO_STORAGE_ROOT=D:\RDSO

# Comma-separated allowed hosts (production only, ignored when DEBUG=True)
# ALLOWED_HOSTS=example.com,api.example.com

# Comma-separated CORS origins (production only, ignored when DEBUG=True)
# CORS_ALLOWED_ORIGINS=https://example.com,https://app.example.com
